apiVersion: argoproj.io/v1alpha1
kind: ApplicationSet
metadata:
  name: apps-manual-sync
spec:
  generators:
    - git:
        repoURL: https://github.com/Endeshaw90/Projects.git
        revision: main
        directories:
          - path: apps/*
  template:
    metadata:
      name: '{{path.basename}}'
    spec:
      project: default
      source:
        repoURL: https://github.com/Endeshaw90/Projects.git
        targetRevision: main
        path: '{{path}}'
      destination:
        server: https://kubernetes.default.svc
        namespace: default
      syncPolicy: {}   # manual sync only

